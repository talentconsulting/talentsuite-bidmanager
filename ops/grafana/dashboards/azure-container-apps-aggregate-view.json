      "targets": [
        {
          "azureMonitor": {
            "dimensionFilters": [],
            "timeGrain": "auto"
          },
          "azureResourceGraph": {
            "query": "Resources\r\n| where subscriptionId =~ '$sub'\r\n| where resourceGroup =~ '$rg'\r\n| where type =~ 'microsoft.app/containerapps'\r\n| extend props = todynamic(properties)\r\n| extend environmentId = tostring(props.managedEnvironmentId)\r\n| where isnotempty(environmentId)\r\n| extend environmentName = tostring(split(environmentId, \"/\")[-1])\r\n| where environmentName =~ '$res'\r\n| extend \r\n    appName = name,\r\n    region = location,\r\n    latestRevision = tostring(props.latestRevisionName),\r\n    activeRevisionMode = tostring(props.configuration.activeRevisionsMode),\r\n    workloadProfileName = tostring(props.workloadProfileName)\r\n| extend\r\n    workloadType = iif(isempty(workloadProfileName), \"NA - Consumption Only\", iif(workloadProfileName =~ \"Consumption\", \"Consumption\", \"Dedicated\"))\r\n| extend\r\n    minReplicas = toint(props.template.scale.minReplicas),\r\n    maxReplicas = toint(props.template.scale.maxReplicas),\r\n    runningStatus = tostring(props.runningStatus),\r\n    containers = props.template.containers,\r\n    link = \"Go to dashboard\"\r\n| mv-expand container = containers\r\n| extend \r\n    containerImage = tostring(container.image),\r\n    containerCPU = todouble(container.resources.cpu),\r\n    containerMemory = todouble(split(tostring(container.resources.memory), \"G\")[0])\r\n| project \r\n    [\"App Name\"] = appName,\r\n    [\"Workload Type\"] = workloadType,\r\n    [\"Latest Revision\"] = latestRevision,\r\n    [\"Region\"] = region,\r\n    [\"Revision Mode\"] = activeRevisionMode,\r\n    [\"Min Replicas\"] = minReplicas,\r\n    [\"Max Replicas\"] = maxReplicas,\r\n    [\"Running Status\"] = runningStatus,\r\n    [\"Container Image\"] = containerImage,\r\n    [\"Container CPU (cores)\"] = containerCPU,\r\n    [\"Container Memory (Gi)\"] = containerMemory,\r\n    [\"Link\"] = link\r\n"
          },
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "${am_ds}"
          },
          "queryType": "Azure Resource Graph",
          "refId": "A",
          "subscription": "",
          "subscriptions": [
            "$sub"
          ]
        }
      ],
