@namespace TalentSuite.FrontEnd.Pages.Bids.Management
@using TalentSuite.FrontEnd.Pages.Bids.Management.Models
@using TalentSuite.Shared.Bids

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <h4 class="mb-3">Progress</h4>
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <div class="p-3 border rounded bg-light">
                    <div class="text-muted small">Questions without a final response</div>
                    <div class="fs-4 fw-bold">@QuestionsWithoutFinalAnswerCount</div>
                    <div class="mt-2 small text-muted">
                        @FinalAnswersCompletedCount / @TotalQuestionsCount with a final response
                    </div>
                    <div class="progress mt-2" role="progressbar" aria-label="Final response progress"
                         aria-valuenow="@FinalAnswerProgressPercent" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar bg-success"
                             style="width: @($"{FinalAnswerProgressPercent}%")">
                            @FinalAnswerProgressPercent%
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <div class="p-3 border rounded bg-light">
                    <div class="text-muted small">Questions without assigned users</div>
                    <div class="fs-4 fw-bold">@QuestionsWithoutUsersCount</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h4 class="mb-3">Overview</h4>

        @if (Bid.BidLibraryPush is not null)
        {
            <div class="alert alert-success mb-3">
                This bid was pushed to the bid library on @Bid.BidLibraryPush.PushedAtUtc.ToLocalTime().ToString("g").
            </div>
        }

        <div class="d-flex flex-column gap-3">
            <div class="p-3 border rounded bg-light">
                <div class="text-muted small">Stage</div>
                <div class="fw-semibold">@GetStageLabel(Bid.Stage)</div>
            </div>

            <div class="p-3 border rounded bg-light">
                <div class="text-muted small">Unique reference</div>
                <div>@FormatOrDash(Bid.UniqueReference)</div>
            </div>

            <div class="p-3 border rounded bg-light">
                <div class="text-muted small">Summary</div>
                <div style="white-space: pre-wrap;">@FormatOrDash(Bid.Summary)</div>
            </div>

            <div class="p-3 border rounded bg-light">
                <div class="text-muted small">Key information</div>
                <div style="white-space: pre-wrap;">@FormatOrDash(Bid.KeyInformation)</div>
            </div>

            <div class="p-3 border rounded bg-light">
                <div class="text-muted small">Budget</div>
                <div>@FormatOrDash(Bid.Budget)</div>
            </div>

            <div class="p-3 border rounded bg-light">
                <div class="text-muted small">Deadline for submission</div>
                <div>@FormatOrDash(Bid.DeadlineForSubmission)</div>
            </div>

            <div class="p-3 border rounded bg-light">
                <div class="text-muted small">Deadline for qualifying</div>
                <div>@FormatOrDash(Bid.DeadlineForQualifying)</div>
            </div>

            <div class="p-3 border rounded bg-light">
                <div class="text-muted small">Length of contract</div>
                <div>@FormatOrDash(Bid.LengthOfContract)</div>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="OnGoToQuestions">
                Go to questions →
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public BidManageModel Bid { get; set; } = default!;
    [Parameter] public int QuestionsWithoutFinalAnswerCount { get; set; }
    [Parameter] public int QuestionsWithoutUsersCount { get; set; }
    [Parameter] public EventCallback OnGoToQuestions { get; set; }

    private int TotalQuestionsCount => Bid?.Questions?.Count ?? 0;
    private int FinalAnswersCompletedCount => Math.Max(0, TotalQuestionsCount - QuestionsWithoutFinalAnswerCount);
    private int FinalAnswerProgressPercent
        => TotalQuestionsCount == 0
            ? 0
            : (int)Math.Round((double)FinalAnswersCompletedCount * 100 / TotalQuestionsCount);

    private static string GetStageLabel(BidStage stage)
        => stage switch
        {
            BidStage.Stage1 => "Stage 1",
            BidStage.Stage2 => "Stage 2",
            _ => stage.ToString()
        };

    private static string FormatOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;
}
